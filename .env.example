# ============================================================================
# Model Proxy Configuration
# ============================================================================

# Server Configuration
PORT=3000
NODE_ENV=development

# Internal API Key for proxy authentication
# Generate a secure key: openssl rand -hex 32
MODEL_PROXY_API_KEY=your-secure-proxy-api-key-here

# ============================================================================
# Provider API Keys
# At least one provider must be configured
# ============================================================================

# NVIDIA NIM (Free tier - highest priority)
# Get your key: https://build.nvidia.com/
NVIDIA_NIM_API_KEY=nvapi-your-nvidia-nim-api-key

# OpenCode (Subscription & Free tiers)
# Get your key: https://opencode.ai/
OPENCODE_API_KEY=your-opencode-api-key

# Groq (Free tier with limits)
# Get your key: https://console.groq.com/
GROQ_API_KEY=gsk_your-groq-api-key

# Cerebras (Free tier available)
CEREBRAS_API_KEY=your-cerebras-api-key

# SambaNova (Free tier available)
SAMBANOVA_API_KEY=your-sambanova-api-key

# Together AI
TOGETHER_API_KEY=your-together-api-key

# Fireworks AI
FIREWORKS_API_KEY=your-fireworks-api-key

# Hyperbolic
HYPERBOLIC_API_KEY=your-hyperbolic-api-key

# OpenRouter
OPENROUTER_API_KEY=your-openrouter-api-key

# ============================================================================
# Health Check Configuration
# ============================================================================

# Timeout for health checks (ms)
HEALTH_CHECK_TIMEOUT_MS=5000

# Cache TTL for health results (ms) - default 5 minutes
HEALTH_CHECK_CACHE_TTL_MS=300000

# ============================================================================
# Circuit Breaker Configuration
# ============================================================================

# Number of failures before circuit opens
CIRCUIT_BREAKER_THRESHOLD=5

# Time before circuit resets (ms)
CIRCUIT_BREAKER_RESET_MS=60000

# ============================================================================
# Preference Configuration
# ============================================================================

# Prefer free providers (1 = true, 0 = false)
PREFER_FREE_PROVIDERS=1

# Provider priority order (comma-separated list)
# Options: nvidia-nim, opencode-go, opencode-zen, groq, cerebras, sambanova, together, fireworks, hyperbolic, openrouter
PROVIDER_PRIORITY=nvidia-nim,opencode-go,groq

# Max acceptable latency in milliseconds
MAX_LATENCY_MS=5000

# Fallback strategy: priority | latency | cost | availability
FALLBACK_STRATEGY=priority

# ============================================================================
# Logging
# ============================================================================

# Log level: debug | info | warn | error
LOG_LEVEL=info
