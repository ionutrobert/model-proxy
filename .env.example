# ============================================================================
# Model Proxy Configuration
# ============================================================================

# Server Configuration
PORT=3000
NODE_ENV=development

# Internal API Key for proxy authentication
# Auto-generated if not set (check logs on first run)
# To generate manually: openssl rand -hex 32
MODEL_PROXY_API_KEY=

# ============================================================================
# Provider API Keys
# At least one provider must be configured
# ============================================================================

# Single key format (backward compatible):
# NVIDIA_NIM_API_KEY=nvapi-xxx
#
# Multiple keys format (NEW - for key rotation):
# NVIDIA_NIM_API_KEYS=nvapi-xxx,nvapi-yyy,nvapi-zzz
#
# Or numbered format:
# NVIDIA_NIM_API_KEY_1=nvapi-xxx
# NVIDIA_NIM_API_KEY_2=nvapi-yyy
#
# Priority: KEYS > KEY_1, KEY_2... > KEY

# NVIDIA NIM (Free tier - highest priority)
# Get your key: https://build.nvidia.com/
NVIDIA_NIM_API_KEY=nvapi-your-nvidia-nim-api-key
# NVIDIA_NIM_API_KEYS=nvapi-key1,nvapi-key2,nvapi-key3

# OpenCode (Subscription & Free tiers)
# Get your key: https://opencode.ai/
OPENCODE_API_KEY=your-opencode-api-key

# Groq (Free tier with limits)
# Get your key: https://console.groq.com/
GROQ_API_KEY=gsk_your-groq-api-key

# Cerebras (Free tier available)
CEREBRAS_API_KEY=your-cerebras-api-key

# SambaNova (Free tier available)
SAMBANOVA_API_KEY=your-sambanova-api-key

# Together AI
TOGETHER_API_KEY=your-together-api-key

# Fireworks AI
FIREWORKS_API_KEY=your-fireworks-api-key

# Hyperbolic
HYPERBOLIC_API_KEY=your-hyperbolic-api-key

# OpenRouter
OPENROUTER_API_KEY=your-openrouter-api-key

# ============================================================================
# Key Rotation Configuration (NEW)
# ============================================================================

# Global rotation strategy: on-429 (default) | round-robin
# - on-429: Use key until rate limited, then switch
# - round-robin: Rotate through keys on each request
ROTATION_STRATEGY=on-429

# Per-provider rotation strategy (overrides global)
# Format: {PROVIDER}_ROTATION_STRATEGY
# Example: NVIDIA_NIM_ROTATION_STRATEGY=round-robin
# NVIDIA_NIM_ROTATION_STRATEGY=on-429

# ============================================================================
# Health Check Configuration
# ============================================================================

# Timeout for health checks (ms)
HEALTH_CHECK_TIMEOUT_MS=5000

# Cache TTL for health results (ms) - default 5 minutes
HEALTH_CHECK_CACHE_TTL_MS=300000

# ============================================================================
# Circuit Breaker Configuration
# ============================================================================

# Number of failures before circuit opens
CIRCUIT_BREAKER_THRESHOLD=5

# Time before circuit resets (ms)
CIRCUIT_BREAKER_RESET_MS=60000

# ============================================================================
# Preference Configuration
# ============================================================================

# Prefer free providers (1 = true, 0 = false)
PREFER_FREE_PROVIDERS=1

# Provider priority order (comma-separated list)
# Options: nvidia-nim, opencode-go, opencode-zen, groq, cerebras, sambanova, together, fireworks, hyperbolic, openrouter
PROVIDER_PRIORITY=nvidia-nim,opencode-go,groq

# Max acceptable latency in milliseconds
MAX_LATENCY_MS=5000

# Fallback strategy: priority | latency | cost | availability
FALLBACK_STRATEGY=priority

# ============================================================================
# Health Tracking Configuration (NEW)
# ============================================================================

# Enable passive health tracking (1 = true, 0 = false)
HEALTH_TRACKING_ENABLED=1

# Rolling window size - number of requests to store per model
HEALTH_ROLLING_WINDOW_SIZE=20

# Maximum age for health data (ms) - default 1 hour
HEALTH_MAX_AGE_MS=3600000

# ============================================================================
# Background Polling Configuration (NEW)
# ============================================================================

# Enable background polling for unhealthy/unknown models (1 = true, 0 = false)
BACKGROUND_POLLING_ENABLED=1

# Polling interval (ms) - time between poll cycles
BACKGROUND_POLL_INTERVAL_MS=10000

# Poll timeout (ms) - max time per individual poll
BACKGROUND_POLL_TIMEOUT_MS=15000

# Max concurrent polls (keep at 1 to avoid rate limits)
BACKGROUND_POLL_MAX_CONCURRENT=1

# ============================================================================
# Auto-Modes Configuration (NEW)
# ============================================================================

# Auto-Coding: Minimum tier for coding models
# Options: S+, S, A+, A, A-, B+, B, C
AUTO_CODING_MIN_TIER=A

# Auto-Coding: Minimum context window (tokens)
AUTO_CODING_MIN_CONTEXT=80000

# Auto-Coding: Prefer thinking/reasoning models (1 = true, 0 = false)
AUTO_CODING_PREFER_THINKING=1

# Auto-Fast: Maximum acceptable latency (ms)
AUTO_FAST_MAX_LATENCY_MS=1000

# Auto-Balanced: Minimum tier
AUTO_BALANCED_MIN_TIER=A-

# Auto-Balanced: Minimum stability score (0-100)
AUTO_BALANCED_STABILITY_THRESHOLD=60

# ============================================================================
# Stability Score Weights (NEW)
# ============================================================================

# P95 latency weight (0-1)
STABILITY_P95_WEIGHT=0.3

# Jitter weight (0-1)
STABILITY_JITTER_WEIGHT=0.3

# Spike rate weight (0-1)
STABILITY_SPIKE_WEIGHT=0.2

# Uptime weight (0-1)
STABILITY_UPTIME_WEIGHT=0.2

# ============================================================================
# Logging
# ============================================================================

# Log level: debug | info | warn | error
LOG_LEVEL=info
